{
  "template_name": "default_firewall_from_44495",
  "source": {
    "firewall_id": 44495,
    "firewall_name": "Edge Firewall Template Azion"
  },
  "defaults": {
    "active": false,
    "debug": false
  },
  "firewall": {
    "source_id": 44495,
    "name": "Edge Firewall Template Azion",
    "modules": {
      "ddos_protection": {
        "enabled": true
      },
      "functions": {
        "enabled": true
      },
      "network_protection": {
        "enabled": true
      },
      "waf": {
        "enabled": true
      }
    },
    "debug": false,
    "active": false
  },
  "functions": [],
  "request_rules": [
    {
      "source_id": 85327,
      "name": "[DROP] Protect TOR Network",
      "active": false,
      "criteria": [
        [
          {
            "conditional": "if",
            "variable": "${network}",
            "operator": "is_in_list",
            "argument": 2
          }
        ]
      ],
      "behaviors": [
        {
          "type": "drop"
        }
      ],
      "description": "Bloqueio dos nó de saida da rede tor  :: status = 444",
      "order": 0
    },
    {
      "source_id": 85328,
      "name": "[DENY] - UA Invalidos",
      "active": false,
      "criteria": [
        [
          {
            "conditional": "if",
            "variable": "${header_user_agent}",
            "operator": "matches",
            "argument": "Mozilla/[1-4]|Chrome(\\/|\\:|\\ |:\\ )[1-9][0-9]\\.|Chrome\\/101\\.0|Firefox(\\/|\\:|\\ |:\\ )[1-9][0-9]\\."
          },
          {
            "conditional": "and",
            "variable": "${header_user_agent}",
            "operator": "does_not_match",
            "argument": "(facebookexternalhit|Twitterbot|[P|p]interest|AdsBot-Google|AppEngine-Google|[G|g]ooglebot|Google\\ SketchUp|Mediapartners-Google|GoogleImageProxy|googleweblight|Google-Read-Aloud|bingbot|BingPreview|msnbot|WhatsApp|YahooSeeker|YahooMobileMail|Yahoo!|Outlook|Slackbot|Slack-ImgProxy|Yandex|SemrushBot|Amazon-Route53-Health-Check|FreshpingBot|PingdomTMS|[P|p]ingdom\\.com|[a|A]pplebot|Storebot-Google|GoogleOther|Google-Site-Verification|FeedFetcher-Google|GoogleProducer|APIs-Google\\.html|Google-InspectionTool|[lL]ighthouse)"
          },
          {
            "conditional": "and",
            "variable": "${header_user_agent}",
            "operator": "does_not_match",
            "argument": "(Amazon-Route53-Health-Check-Service|simplex|gpa-allow-az-botm-v1|GoogleAssociationService)"
          }
        ]
      ],
      "behaviors": [
        {
          "type": "deny"
        }
      ],
      "description": "Relação de UA inválidos",
      "order": 1
    },
    {
      "source_id": 85338,
      "name": "[WAF] Template",
      "active": false,
      "criteria": [
        [
          {
            "conditional": "if",
            "variable": "${request_uri}",
            "operator": "does_not_match",
            "argument": "\\.(css|js|ttf|eof|woff|woff2|svg|jpg|jpeg|gif|bmp|png|ico)(\\?.*)?$"
          }
        ]
      ],
      "behaviors": [
        {
          "type": "set_waf",
          "attributes": {
            "waf_id": 14289,
            "mode": "logging"
          }
        }
      ],
      "description": "Após regras acima na camada 3 e 4, agora vamos invocar o WAF camada 7",
      "order": 2
    }
  ]
}